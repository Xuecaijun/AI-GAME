OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=your-model-name
AI_GAME_FORCE_MOCK=0

# Volcengine (Doubao) TTS v3 (HTTP Chunked)
# Get your API Key from Volcengine console (new console recommended)
VOLC_TTS_API_KEY=
# e.g. seed-tts-2.0 / seed-tts-1.0 / seed-icl-2.0 ... (see temp/tts-api.md)
VOLC_TTS_RESOURCE_ID=seed-tts-1.0
# speaker id, e.g. zh_female_shuangkuaisisi_moon_bigtts
VOLC_TTS_SPEAKER=zh_female_shuangkuaisisi_moon_bigtts
# mp3 / ogg_opus / pcm
VOLC_TTS_FORMAT=mp3
# 8000/16000/24000/44100/48000...
VOLC_TTS_SAMPLE_RATE=24000
